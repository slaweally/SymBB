<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SymBB{% endblock %}</title>
    <link rel="alternate" type="application/rss+xml" title="Son Konular (RSS 2.0)" href="{{ path('app_board_index') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Asap:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('themes/default/css/color.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/default/css/global.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/default/css/css3.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/default/css/thread_status.css') }}">
    <link rel="stylesheet" href="{{ asset('themes/default/css/star_ratings.css') }}">
    <link rel="shortcut icon" href="{{ asset('themes/default/images/tek/fav.png') }}">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
</head>
<body>
<!-- Curves UI Header -->
<nav class="navbar navbar-dark navbar-expand-lg bg-dark py-4 border-bottom-nav">
    <div class="container-md">
        <a class="d-flex align-items-center menu" href="{{ path('app_board_index') }}" style="text-decoration: none">
            <h2 class="text-white mb-0 pb-0 menu" style="text-decoration: none">
                <i class="fa-solid fa-comments"></i>
                <span class="fw-semibold fst-italic logo">SymBB</span>
            </h2>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navcol-3" aria-label="Menü">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="navcol-3" class="collapse navbar-collapse align-items-end">
            <ul class="navbar-nav mx-auto align-items-end me-0"></ul>
            <ul class="list-inline d-flex flex-column flex-sm-column flex-md-column flex-lg-row flex-xl-row flex-xxl-row mx-0" style="margin-bottom: 0px">
                <li class="list-inline-item"><a href="{{ path('app_memberlist') }}" class="top pt-2 pt-sm-2 pt-md-2 pt-lg-0 pt-xl-0 pt-xxl-0"><i class="fa-solid fa-users text-muted"></i> &nbsp;Üyeler</a></li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid bg-nav py-2 m-0 p-0 mb-2 fs-6">
    <div class="container-md">
        <div class="row m-auto">
            <div class="col align-self-center ps-0 ms-0">
                {% if app.user %}
                <ul class="list-inline mt-0 mb-0" style="margin-bottom: 0px">
                    <li class="list-inline-item">
                        <div class="dropdown">
                            <a href="#" aria-expanded="true" data-bs-toggle="dropdown" type="button">
                                <i class="fa-solid fa-circle-user"></i> &nbsp;{{ app.user|format_name }} <i class="fa-solid fa-angle-down small"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-start border rounded" data-bs-popper="none" style="width: 250px">
                                <div class="row p-2">
                                    <div class="col align-self-center">
                                        <a href="{{ path('app_usercp') }}" class="dropdown-item pb-2 ms-0 ps-0" style="border-bottom: 1px solid #b3b3b3"><i class="fa-solid fa-user-gear"></i> &nbsp;Kullanıcı Paneli</a>
                                        {% if is_granted('ROLE_MODERATOR') or is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('app_modcp') }}" class="dropdown-item ms-0 ps-0"><i class="fa-solid fa-screwdriver-wrench"></i> &nbsp;Mod Paneli</a>
                                        {% endif %}
                                        {% if is_granted('ROLE_ADMIN') %}
                                        <a href="/admin/" class="dropdown-item ms-0 ps-0"><i class="fa-solid fa-gears"></i> &nbsp;Yönetim</a>
                                        {% endif %}
                                        <a rel="nofollow" class="dropdown-item ms-0 ps-0" href="{{ path('app_logout') }}"><i class="fa-solid fa-right-from-bracket"></i> &nbsp;Çıkış</a>
                                    </div>
                                    <div class="col-auto align-self-center">
                                        <img src="{{ asset(app.user.avatarUrl) }}" style="height: 80px; width: 80px" class="rounded border" alt="{{ app.user.username }}">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </li>
                    <li class="list-inline-item ms-2">
                        <a href="{{ path('app_private_message') }}" title="Özel Mesajlar"><i class="fa-solid fa-envelope"></i> &nbsp;Özel Mesajlar</a>
                    </li>
                    <li class="list-inline-item ms-2 d-none d-sm-none d-md-none d-lg-inline-block"><a href="{{ path('app_search', {action: 'getnew'}) }}"><i class="fa-solid fa-comments"></i> &nbsp;Yeni Mesajlar</a></li>
                    <li class="list-inline-item ms-2 d-none d-sm-none d-md-none d-lg-inline-block"><a href="{{ path('app_search', {action: 'getdaily'}) }}"><i class="fa-solid fa-calendar"></i> &nbsp;Bugünkü Mesajlar</a></li>
                </ul>
                {% else %}
                <ul class="list-inline" style="margin-bottom: 0px">
                    <li class="list-inline-item"><a href="{{ path('app_login') }}" class="login"><i class="fa-solid fa-right-to-bracket fs-6"></i> &nbsp;Giriş</a></li>
                    <li class="list-inline-item"><a href="{{ path('app_register') }}"><i class="fa-solid fa-user fs-6"></i> &nbsp;Kayıt Ol</a></li>
                </ul>
                {% endif %}
            </div>
            <div class="col-4 align-self-center text-end me-0 pe-0">
                <div class="d-none d-sm-none d-md-none d-lg-block d-xl-block d-xxl-block">
                    <form action="{{ path('app_search') }}" method="get">
                        <div class="input-group border" style="border-color: #dee2e6!important;">
                            <input class="form-control form-control-sm border-0 border-end-0" style="border-color: #dee2e6!important;" name="keywords" placeholder="Ara..." type="text" />
                            <button class="btn-sm btn-search border-0 rounded-start-0 border-start-0 border-end" style="border-right: 0px!important" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                            <input type="hidden" name="action" value="do_search" />
                            <input type="hidden" name="postthread" value="1" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid navigation m-0 p-0 mb-0">
    <div class="container-md">
        <div class="navigation py-2">
            {% block breadcrumb %}<a href="{{ path('app_board_index') }}">Ana Sayfa</a>{% endblock %}
        </div>
    </div>
</div>

<div class="container-md mt-2">
    {% for type in ['success', 'error'] %}
        {% for message in app.flashes(type) %}
            <div class="flash-messages"><div class="flash-{{ type }}">{{ message }}</div></div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</div>

<!-- Curves UI Footer -->
<div class="container-fluid mt-5 py-3 bg-nav">
    <div class="container-md">
        <div class="row flex m-auto text-14">
            <div class="col-lg d-flex flex-column justify-content-between">
                <a href="{{ path('app_board_index') }}" class="links"><i class="fa-solid fa-house"></i> &nbsp;Ana Sayfa</a>
            </div>
            <div class="col-lg d-flex flex-column justify-content-between">
                <a href="#top" class="links"><i class="fa-solid fa-circle-arrow-up"></i> &nbsp;Yukarı Dön</a>
            </div>
            <div class="col-lg d-flex flex-column justify-content-between">
                <a href="{{ path('app_misc', {action: 'markread', _token: csrf_token('markread')}) }}" class="links"><i class="fa-solid fa-circle-dot"></i> &nbsp;Tümünü Okundu İşaretle</a>
            </div>
            <div class="col-lg d-flex flex-column justify-content-between">
                <a href="{{ path('app_misc', {action: 'help'}) }}" class="links"><i class="fa-solid fa-circle-question"></i> &nbsp;Yardım</a>
            </div>
        </div>
    </div>
</div>

<div class="container-md">
    <div class="row g-1 mt-3 mb-3 text-14">
        <div class="col-lg align-self-center text-center text-muted">
            <a href="http://www.mybb.com/" target="_blank" rel="noopener" class="links">MyBB</a> tabanlı. Made with <i class="fa-regular fa-heart" style="color: #ee8686;"></i> by <a href="https://www.curvesui.com/" target="_blank" class="links">Curves UI</a>.
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
<script src="{{ asset('themes/default/js/custom.js') }}"></script>
</body>
</html>
