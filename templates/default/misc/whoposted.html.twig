{% extends 'default/base.html.twig' %}

{% block title %}Kim Yazdı — {{ thread.subject }} — SymBB{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_board_index') }}" class="btn-link">Ana Sayfa</a> &raquo;
    <a href="{{ path('app_forum_display', {fid: thread.fid}) }}" class="btn-link">Forum</a> &raquo;
    <a href="{{ path('app_thread_show', {tid: thread.tid}) }}" class="btn-link">{{ thread.subject }}</a> &raquo; Kim Yazdı
{% endblock %}

{% block body %}
    <div class="whoposted-header">
        <h1>Konuya Kim Yazdı: {{ thread.subject }}</h1>
        <p class="text-muted">Toplam {{ total_posts|number_format(0, ',', '.') }} mesaj</p>
    </div>
    <div class="flex-gap">
        <a href="{{ path('app_misc', {action: 'whoposted', tid: thread.tid, sort: 'posts'}) }}" class="btn-link">Mesaj sayısına göre</a>
        <a href="{{ path('app_misc', {action: 'whoposted', tid: thread.tid, sort: 'username'}) }}" class="btn-link">Kullanıcı adına göre</a>
    </div>
    <table class="whoposted-table">
        <thead>
            <tr>
                <th>Kullanıcı</th>
                <th>Mesaj</th>
            </tr>
        </thead>
        <tbody>
            {% for poster in posters %}
            <tr>
                <td>
                    {% if poster.uid %}
                        <a href="{{ path('app_member', {action: 'profile', uid: poster.uid}) }}">{{ poster.username }}</a>
                    {% else %}
                        {{ poster.username }}
                    {% endif %}
                </td>
                <td class="text-right">{{ poster.posts|number_format(0, ',', '.') }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
