{% extends 'default/base.html.twig' %}

{% block title %}Yeni Konu — {{ forum.name }} — SymBB{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css">
{% endblock %}

{% block body %}
    <div class="breadcrumb">
        <a href="{{ path('app_board_index') }}">Ana Sayfa</a> &raquo;
        <a href="{{ path('app_forum_display', {fid: forum.fid}) }}">{{ forum.name }}</a> &raquo;
        Yeni Konu
    </div>

    <div class="new-thread-card">
        <h1>Yeni Konu Ac — {{ forum.name }}</h1>

        {% if error %}
            <div class="form-error">{{ error }}</div>
        {% endif %}

        <form method="post" id="thread-form" enctype="multipart/form-data" onsubmit="return syncEditor()">
            {% if draft_tid %}
                <input type="hidden" name="draft_tid" value="{{ draft_tid }}">
            {% endif %}
            <div class="form-group">
                <label for="subject">Konu Basligi</label>
                <input type="text" id="subject" name="subject" value="{{ draft_subject|default(app.request.request.get('subject', '')) }}" required autofocus maxlength="120">
            </div>
            <div class="form-group">
                <label>Mesaj</label>
                <div id="editor"></div>
                <input type="hidden" name="message" id="hidden_message">
            </div>
            <div class="form-group">
                <label for="attachments">Eklentiler</label>
                <input type="file" id="attachments" name="attachments[]" multiple accept=".jpg,.jpeg,.png,.gif,.pdf,.zip,.rar">
                <small class="form-hint">Izın verilen: jpg, png, gif, pdf, zip, rar. Maks 5MB.</small>
            </div>
            <div class="btn-row">
                <button type="submit" class="btn-primary">Konuyu Gonder</button>
                <button type="submit" name="savedraft" value="1" class="btn-draft" formnovalidate>Taslak Olarak Kaydet</button>
                <a href="{{ path('app_forum_display', {fid: forum.fid}) }}" class="btn-back">Vazgec</a>
            </div>
        </form>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
    <script>
        let editor;
        document.addEventListener('DOMContentLoaded', function() {
            editor = new toastui.Editor({
                el: document.querySelector('#editor'),
                height: '300px',
                initialEditType: 'wysiwyg',
                previewStyle: 'vertical',
                initialValue: {{ (draft_message|default(app.request.request.get('message', '')))|json_encode|raw }}
            });
        });

        function syncEditor() {
            if (editor) {
                document.getElementById('hidden_message').value = editor.getHTML();
            }
            return true;
        }
    </script>
{% endblock %}
