{% extends 'default/base.html.twig' %}

{% block title %}Sifre Degistir — Kontrol Paneli — SymBB{% endblock %}

{% block stylesheets %}{% endblock %}

{% block body %}
    <div class="cp-container">
        <div class="cp-menu">
            <h3>Profil</h3>
            <ul>
                <li><a href="{{ path('app_usercp') }}">Genel Bakis</a></li>
                <li><a href="{{ path('app_usercp', {action: 'profile'}) }}">Profil Duzenle</a></li>
                <li><a href="{{ path('app_usercp', {action: 'editsig'}) }}">Imza Duzenle</a></li>
                <li><a href="{{ path('app_usercp', {action: 'options'}) }}">Secenekleri Duzenle</a></li>
                <li><a href="{{ path('app_usercp', {action: 'subscriptions'}) }}">Konu Abonelikleri</a></li>
                <li><a href="{{ path('app_usercp', {action: 'drafts'}) }}">Taslaklar</a></li>
                <li><a href="{{ path('app_usercp', {action: 'password'}) }}" class="active">Sifre Degistir</a></li>
                <li><a href="{{ path('app_usercp', {action: 'email'}) }}">E-posta Degistir</a></li>
                <li><a href="{{ path('app_usercp', {action: 'avatar'}) }}">Avatar Yukle</a></li>
            </ul>
        </div>
        <div class="cp-content">
            <h1>Sifre Degistir</h1>
            {% if error %}
                <div class="alert-error">{{ error }}</div>
            {% endif %}
            <form method="post">
                <div class="form-group">
                    <label for="old_password">Mevcut Sifre</label>
                    <input type="password" id="old_password" name="old_password" required>
                </div>
                <div class="form-group">
                    <label for="new_password">Yeni Sifre</label>
                    <input type="password" id="new_password" name="new_password" required minlength="6">
                </div>
                <div class="form-group">
                    <label for="confirm_password">Yeni Sifre (Tekrar)</label>
                    <input type="password" id="confirm_password" name="confirm_password" required minlength="6">
                </div>
                <button type="submit" class="btn-primary">Sifreyi Guncelle</button>
            </form>
        </div>
    </div>
{% endblock %}
