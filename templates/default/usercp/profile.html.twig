{% extends 'default/base.html.twig' %}

{% block title %}Profil Duzenle — Kontrol Paneli — SymBB{% endblock %}

{% block stylesheets %}{% endblock %}

{% block body %}
    <div class="cp-container">
        <div class="cp-menu">
            <h3>Profil</h3>
            <ul>
                <li><a href="{{ path('app_usercp') }}">Genel Bakis</a></li>
                <li><a href="{{ path('app_usercp', {action: 'profile'}) }}" class="active">Profil Duzenle</a></li>
                <li><a href="{{ path('app_usercp', {action: 'editsig'}) }}">Imza Duzenle</a></li>
                <li><a href="{{ path('app_usercp', {action: 'options'}) }}">Secenekleri Duzenle</a></li>
                <li><a href="{{ path('app_usercp', {action: 'subscriptions'}) }}">Konu Abonelikleri</a></li>
                <li><a href="{{ path('app_usercp', {action: 'drafts'}) }}">Taslaklar</a></li>
                <li><a href="{{ path('app_usercp', {action: 'password'}) }}">Sifre Degistir</a></li>
                <li><a href="{{ path('app_usercp', {action: 'email'}) }}">E-posta Degistir</a></li>
                <li><a href="{{ path('app_usercp', {action: 'avatar'}) }}">Avatar Yukle</a></li>
            </ul>
        </div>
        <div class="cp-content">
            <h1>Profil Duzenle</h1>
            {% if error %}
                <div class="alert-error">{{ error }}</div>
            {% endif %}
            <form method="post">
                <table class="tborder" style="width: 100%;">
                    <tr>
                        <td class="trow1" style="width: 180px;"><strong>Konum</strong></td>
                        <td class="trow1"><input type="text" name="location" value="{{ user.location|default('') }}" class="form-control" style="max-width: 300px;"></td>
                    </tr>
                    <tr>
                        <td class="trow2"><strong>Skype</strong></td>
                        <td class="trow2"><input type="text" name="skype" value="{{ user.skype|default('') }}" class="form-control" style="max-width: 300px;"></td>
                    </tr>
                    <tr>
                        <td class="trow1"><strong>Google</strong></td>
                        <td class="trow1"><input type="text" name="google" value="{{ user.google|default('') }}" class="form-control" style="max-width: 300px;"></td>
                    </tr>
                    <tr>
                        <td class="trow2"><strong>ICQ</strong></td>
                        <td class="trow2"><input type="text" name="icq" value="{{ user.icq|default('') }}" class="form-control" style="max-width: 300px;"></td>
                    </tr>
                    <tr>
                        <td class="tfoot" colspan="2"><button type="submit" class="button">Kaydet</button></td>
                    </tr>
                </table>
            </form>
        </div>
    </div>
{% endblock %}
