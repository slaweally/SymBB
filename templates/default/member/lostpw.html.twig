{% extends 'default/base.html.twig' %}

{% block title %}Sifremi Unuttum — SymBB{% endblock %}

{% block stylesheets %}{% endblock %}

{% block body %}
    <div class="breadcrumb">
        <a href="{{ path('app_board_index') }}">Ana Sayfa</a> &raquo; Sifremi Unuttum
    </div>

    <div class="lostpw-card">
        <h1>Sifremi Unuttum</h1>

        {% for message in app.flashes('error') %}
            <div class="flash-message flash-error">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('success') %}
            <div class="flash-message flash-success">{{ message }}</div>
        {% endfor %}

        <form method="post" action="{{ path('app_member', {action: 'lostpw'}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('lostpw') }}">
            <div class="form-group">
                <label for="email">E-posta Adresiniz</label>
                <input type="email" id="email" name="email" class="form-control" required>
            </div>
            <button type="submit" class="btn-primary">Sifre Sifirlama Linki Gonder</button>
        </form>
    </div>
{% endblock %}
