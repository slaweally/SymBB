{% extends 'default/base.html.twig' %}

{% block title %}Konuyu Gönder — {{ thread.subject }} — SymBB{% endblock %}

{% block body %}
<div class="max-w-900">
    <div class="breadcrumb">
        <a href="{{ path('app_board_index') }}">Ana Sayfa</a> &raquo;
        <a href="{{ path('app_thread_show', {tid: thread.tid}) }}">{{ thread.subject }}</a> &raquo;
        Konuyu E-posta ile Gönder
    </div>

    <table class="tborder" style="width: 100%;">
        <thead>
            <tr>
                <td class="thead"><strong>Konuyu e-posta ile gönder</strong></td>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="trow1">
                    {% if error %}
                    <div class="alert alert-warning">{{ error }}</div>
                    {% endif %}
                    <form method="post" action="{{ path('app_sendthread', {tid: thread.tid}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('sendthread') }}">
                        <div class="mb-3">
                            <label for="email" class="form-label">Alıcı e-posta</label>
                            <input type="email" id="email" name="email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="fromname" class="form-label">Adınız</label>
                            <input type="text" id="fromname" name="fromname" class="form-control" value="{{ app.user ? app.user.username : '' }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="fromemail" class="form-label">E-posta adresiniz</label>
                            <input type="email" id="fromemail" name="fromemail" class="form-control" value="{{ app.user ? app.user.email : '' }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="subject" class="form-label">Konu</label>
                            <input type="text" id="subject" name="subject" class="form-control" value="Konu: {{ thread.subject }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="message" class="form-label">Mesaj</label>
                            <textarea id="message" name="message" class="form-control" rows="5" placeholder="İsteğe bağlı ek mesaj"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Gönder</button>
                        <a href="{{ path('app_thread_show', {tid: thread.tid}) }}" class="btn btn-outline-secondary">İptal</a>
                    </form>
                </td>
            </tr>
        </tbody>
    </table>
</div>
{% endblock %}
