{% extends 'default/base.html.twig' %}

{% block title %}Klasör Boşalt — SymBB{% endblock %}

{% block body %}
    <div class="max-w-900">
        <div class="breadcrumb">
            <a href="{{ path('app_board_index') }}">Ana Sayfa</a> &raquo;
            <a href="{{ path('app_private_message') }}">Özel Mesajlar</a> &raquo;
            Klasör Boşalt
        </div>
    </div>

    <div class="pm-container">
        <div class="pm-menu">
            <h3>Mesajlar</h3>
            <ul>
                <li><a href="{{ path('app_private_message') }}">Gelen Kutusu</a></li>
                <li><a href="{{ path('app_private_message', {action: 'send'}) }}">Yeni Mesaj Gönder</a></li>
                <li><a href="{{ path('app_private_message', {action: 'tracking'}) }}">Mesaj Takibi</a></li>
                <li><a href="{{ path('app_private_message', {action: 'folders'}) }}">Klasör Yönetimi</a></li>
                <li><a href="{{ path('app_private_message', {action: 'empty'}) }}" class="active">Klasör Boşalt</a></li>
                <li><a href="{{ path('app_private_message', {action: 'export'}) }}">Dışa Aktar</a></li>
            </ul>
        </div>
        <div class="pm-content">
            <h1>Klasör Boşalt</h1>
            <p>Boşaltmak istediğiniz klasörleri seçin. Tüm mesajlar kalıcı olarak silinecektir.</p>

            <form method="post" action="{{ path('app_private_message', {action: 'do_empty'}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('pm_empty') }}">
                <p>
                    <label><input type="checkbox" name="keepunread" value="1"> Okunmamış mesajları koru</label>
                </p>
                <table class="pm-table">
                    <thead>
                        <tr>
                            <th>Klasör</th>
                            <th>Mesaj Sayısı</th>
                            <th>Boşalt</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for f in folders %}
                            <tr>
                                <td>{{ f.name }}</td>
                                <td>{{ counts[f.id]|default(0)|number_format(0, ',', '.') }}</td>
                                <td>
                                    {% if counts[f.id]|default(0) > 0 %}
                                        <input type="checkbox" name="empty[{{ f.id }}]" value="1">
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <button type="submit" class="btn-primary">Seçilen Klasörleri Boşalt</button>
            </form>
        </div>
    </div>
{% endblock %}
