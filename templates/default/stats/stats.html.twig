{% extends 'default/base.html.twig' %}

{% block title %}Forum İstatistikleri — SymBB{% endblock %}

{% block body %}
    <div style="max-width: 600px; margin: 60px auto; padding: 40px; font-family: 'Segoe UI', sans-serif;">
        <h1 style="font-size: 2rem; color: #2c3e50; margin-bottom: 8px;">📊 Forum İstatistikleri</h1>
        <p style="color: #888; margin-bottom: 32px;">Bu sayfa artık <strong>SymBB (Symfony)</strong> tarafından render ediliyor.</p>

        <table style="width: 100%; border-collapse: collapse; font-size: 1.05rem;">
            <tbody>
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 14px 0; color: #555;">👤 Toplam Üye</td>
                    <td style="padding: 14px 0; text-align: right; font-weight: 700; color: #2c3e50;">{{ totalUsers|number_format(0, ',', '.') }}</td>
                </tr>
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 14px 0; color: #555;">📝 Toplam Konu</td>
                    <td style="padding: 14px 0; text-align: right; font-weight: 700; color: #2c3e50;">{{ totalThreads|number_format(0, ',', '.') }}</td>
                </tr>
                <tr>
                    <td style="padding: 14px 0; color: #555;">💬 Toplam Mesaj</td>
                    <td style="padding: 14px 0; text-align: right; font-weight: 700; color: #2c3e50;">{{ totalPosts|number_format(0, ',', '.') }}</td>
                </tr>
            </tbody>
        </table>

        <p style="margin-top: 32px; padding: 12px 24px; background: #e8f5e9; border-radius: 8px; text-align: center; color: #2e7d32; font-weight: 500;">
            ✅ Strangler Fig — Veriler Doctrine ORM ile MyBB veritabanından çekiliyor.
        </p>
    </div>
{% endblock %}
